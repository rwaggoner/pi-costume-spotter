# ---------------------------------------------------------------------------
# Costume Spotter edge configuration.
# Copy to `.env` and edit. Every value here maps to a field in
# costume_spotter/config.py, which documents defaults and validation.
# ---------------------------------------------------------------------------

# dev = laptop: synthetic/webcam camera, mock detector, no hardware needed.
# pi  = Raspberry Pi: Picamera2 + Hailo. (docs/decisions/008-hardware-abstraction.md)
EDGE_PROFILE=dev

# --- Camera ---------------------------------------------------------------
# Unset = follows the profile (dev -> synthetic, pi -> picamera2).
# Set only to override, e.g. webcam demos on a laptop:
#CAMERA_SOURCE=webcam
# Capture resolution. Detection cost is unchanged by this (the model input is a
# fixed size — the detector resizes internally), so raising it only sharpens the
# MJPEG feed and the snapshot crops sent to Claude. 1920x1080 is a good porch
# value on a Pi 5; drop back to 1280x720 if you need CPU headroom.
FRAME_WIDTH=1280
FRAME_HEIGHT=720
TARGET_FPS=15

# --- Detection ------------------------------------------------------------
# Unset = follows the profile (dev -> mock, pi -> hailo).
# Override options: hog (laptop person detection, needs [webcam] extra)
#DETECTOR=hog
DETECTION_CONFIDENCE_THRESHOLD=0.5
# Path to the compiled Hailo model — pi profile only (docs/setup-pi.md step 3).
#HAILO_HEF_PATH=/home/pi/costume-spotter-data/models/yolov8s_h8.hef

# --- Costume identification (Claude Vision) --------------------------------
# Leave unset to run in "pretend" mode: canned costumes, zero cost (03-F7).
#ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5
IDENTIFY_TIMEOUT_SECONDS=15

# --- Tracking -------------------------------------------------------------
# Frames a person must persist before they count as a visitor (02-F3)...
TRACKER_MIN_HITS=5
# ...and seconds out-of-frame before a visitor is forgotten (02-F4).
TRACKER_RETIRE_SECONDS=30

# --- Speech ---------------------------------------------------------------
# piper (local, default) | google (needs [gcp] extra + credentials) | null
TTS_ENGINE=null
#PIPER_VOICE_PATH=/home/pi/costume-spotter-data/voices/en_US-lessac-medium.onnx
# ALSA device for playback on the Pi (find yours: `aplay -l`). dev uses files.
#AUDIO_DEVICE=plughw:1,0
SPEECH_QUEUE_MAX=3

# --- Storage & privacy (docs/requirements/05-storage.md) --------------------
# All runtime data (SQLite DB, snapshots, dev audio output) lives under here.
DATA_DIR=./data
# 0 disables snapshot storage entirely (metadata-only mode, 05-N3).
SNAPSHOT_RETENTION_DAYS=7

# --- API server -------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --- Cloud sync (off by default; docs/setup-gcp.md) -------------------------
CLOUD_SYNC_ENABLED=false
#GCP_PROJECT_ID=my-project
#GCP_PUBSUB_TOPIC=costume-sightings
#GOOGLE_APPLICATION_CREDENTIALS=/path/to/edge-publisher-key.json
DEVICE_ID=porch-pi
